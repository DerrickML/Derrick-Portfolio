# Server
PORT=3003
NODE_ENV=development
SESSION_SECRET=replace_with_a_long_random_session_secret

# Admin Panel
# To generate this during first setup:
#   ADMIN_PASSWORD='your-password' npm run setup
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash

# Email / SMTP
# These are used by the contact form and subscription reminder emails.
# The admin Settings page can override SMTP host, port, secure mode, sender, and recipient.
EMAIL_USERNAME=you@example.com
EMAIL_PASSWORD=replace_with_email_or_app_password
EMAIL_HOST=derrickml.com
EMAIL_PORT=465
EMAIL_TO=you@example.com

# Private Cron
# Must match the Cloudflare Worker CRON_SECRET secret.
CRON_SECRET=replace_with_a_long_random_cron_secret
